package yosh:acp@7.0.0;

/// Methods exported by an agent. The client calls these.
///
/// Maps to the JSON-RPC methods listed under "Agent" in the protocol
/// overview: <https://agentclientprotocol.com/protocol/overview#agent>
///
/// The session lifecycle is resource-shaped: `new-session` /
/// `load-session` / `resume-session` each return an owned [`session`]
/// resource alongside an initial state snapshot. Dropping the
/// `session` closes it; there is no `close-session` method.
///
/// A prompt turn is also resource-shaped: `session.prompt(blocks)`
/// returns a [`prompt-turn`] that exposes the streaming
/// `session-update` body and the eventual final response. Dropping the
/// `prompt-turn` cancels the in-flight turn. This mirrors
/// `wasi:http`'s `handler.handle(request) -> response` shape.
interface agent {
    use errors.{error};
    use init.{initialize-request, initialize-response, authenticate-request};
    use sessions.{
        session-mode-id, session-model-id,
        new-session-request, new-session-response,
        load-session-request, load-session-response,
        list-sessions-request, list-sessions-response,
        resume-session-request, resume-session-response,
    };
    use content.{content-block};
    use prompts.{session-update, prompt-response};

    /// Opaque handle to an active session.
    ///
    /// Returned (owned) from `new-session` / `load-session` /
    /// `resume-session`; dropping the handle closes the session — no
    /// separate `close-session` method.
    resource session {
        /// Begin a prompt turn. Returns an owned [`prompt-turn`] that
        /// streams `session-update`s on its body and resolves a
        /// `prompt-response` when the turn ends. Drop the turn to
        /// cancel; awaiting `response()` resolves with
        /// `stop-reason::cancelled` in that case.
        ///
        /// Multiple concurrent turns on the same session are allowed:
        /// each one is its own resource with its own body stream.
        ///
        /// See: <https://agentclientprotocol.com/protocol/prompt-turn>
        prompt: func(prompt: list<content-block>) -> prompt-turn;

        /// Switch the active mode for this session. The `mode-id` MUST
        /// be one of the modes returned in the session's lifecycle
        /// response.
        ///
        /// See: <https://agentclientprotocol.com/protocol/session-modes>
        set-mode: async func(mode-id: session-mode-id) -> result<_, error>;

        /// Switch the active model for this session. **UNSTABLE**.
        /// The `model-id` MUST be one of the models returned in the
        /// session's lifecycle response.
        select-model: async func(model-id: session-model-id) -> result<_, error>;
    }

    /// An in-flight prompt turn.
    ///
    /// Holds the streaming "body" (session updates as they happen) and
    /// the future final response. Dropping the resource cancels the
    /// turn — the agent MUST resolve `response()` with
    /// `stop-reason::cancelled` and the `updates` stream MUST end
    /// promptly.
    ///
    /// Analogous to `wasi:http/types.response`: the body is consumed
    /// separately from the terminal status.
    resource prompt-turn {
        /// The streaming body of the turn: every `session-update` the
        /// agent emits during the turn arrives here in order. The
        /// stream ends when the turn finishes (whether normally or by
        /// cancellation).
        updates: func() -> stream<session-update>;

        /// The terminal response for this turn. Resolves once the turn
        /// ends. Safe to call before, during, or after consuming the
        /// `updates` stream.
        response: async func() -> result<prompt-response, error>;
    }

    /// Establish the connection. Negotiate protocol version, exchange
    /// capabilities, and identify implementations.
    ///
    /// MUST be the first method called on the agent.
    ///
    /// See: <https://agentclientprotocol.com/protocol/initialization>
    initialize: async func(req: initialize-request) -> result<initialize-response, error>;

    /// Authenticate using one of the methods advertised in
    /// `initialize-response.auth-methods`.
    ///
    /// See: <https://agentclientprotocol.com/protocol/initialization#authentication>
    authenticate: async func(req: authenticate-request) -> result<_, error>;

    /// Create a fresh conversation session. MUST be called after
    /// `initialize`. Returns an owned [`session`] resource paired with
    /// the initial response record.
    ///
    /// See: <https://agentclientprotocol.com/protocol/session-setup#creating-a-session>
    new-session: async func(req: new-session-request) -> result<tuple<session, new-session-response>, error>;

    /// Resume a previous session, replaying its history. The agent
    /// will emit history `session-update`s via a synthetic startup
    /// `prompt-turn` BEFORE this call returns — currently exposed by
    /// the host calling `prompt(...)` on the returned session with an
    /// empty prompt; subject to refinement.
    ///
    /// See: <https://agentclientprotocol.com/protocol/session-setup#loading-sessions>
    load-session: async func(req: load-session-request) -> result<tuple<session, load-session-response>, error>;

    /// Discover existing sessions known to the agent. Pagination via
    /// the opaque `cursor` field.
    ///
    /// See: <https://agentclientprotocol.com/protocol/session-list>
    list-sessions: async func(req: list-sessions-request) -> result<list-sessions-response, error>;

    /// Reconnect to an existing session without replaying history.
    /// Unlike `load-session`, the agent MUST NOT stream history.
    ///
    /// See: <https://agentclientprotocol.com/protocol/session-setup#resuming-sessions>
    resume-session: async func(req: resume-session-request) -> result<tuple<session, resume-session-response>, error>;
}
